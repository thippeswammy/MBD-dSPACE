            flags: PARAM
            range: < 0 ; inf >
            type:  float(64,IEEE)
            unit:  "s"
            value: 0
        }

        ScalingFactor
        {
            addr:  0x3f0e0
            alias: "Scaling Factor"
            desc:  "The scaling factor used for the 'Scaled Time Interval'"
